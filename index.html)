<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CHRONOS // Premium 3D Experience</title>
    
    <!-- Tailwind CSS for modern layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts for sleek typography -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #0a0a0a;
        }
        .heading-font {
            font-family: 'Syne', sans-serif;
        }
        /* Hidden scrollbar but keeps scroll functionality functional */
        ::-webkit-scrollbar {
            width: 0px;
            background: transparent;
        }
        #canvas-container {
            pointer-events: none;
        }
    </style>
</head>
<body class="text-white overflow-x-hidden">

    <!-- Fixed 3D Canvas Background -->
    <div id="canvas-container" class="fixed top-0 left-0 w-full h-full z-10"></div>

    <!-- Background Cinematic Overlay -->
    <div class="fixed top-0 left-0 w-full h-full bg-gradient-to-b from-transparent via-transparent to-[#0a0a0a] z-20 pointer-events-none"></div>

    <!-- Header -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 py-6 mix-blend-difference">
        <a href="#" class="heading-font text-xl font-bold tracking-widest text-white">CHRONOS.</a>
        <button class="border border-white/20 bg-white/5 backdrop-blur-md px-5 py-2 rounded-full text-[10px] uppercase tracking-wider hover:bg-white hover:text-black transition-all duration-300">
            Access Pass
        </button>
    </header>

    <!-- CONTENT LAYERS -->
    <main class="relative z-30 w-full">

        <!-- Hero Section -->
        <section class="h-screen w-full flex items-center px-8 md:px-24">
            <div class="max-w-2xl">
                <span class="text-xs uppercase tracking-[0.3em] text-amber-500 font-semibold inline-block mb-3">01 // Prototype Showcase</span>
                <h1 class="heading-font text-5xl md:text-8xl font-extrabold tracking-tighter leading-none mb-6">
                    DIGITAL <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-neutral-200 to-neutral-600">GRAVITY.</span>
                </h1>
                <p class="text-neutral-400 text-sm md:text-base max-w-sm font-light leading-relaxed mb-8">
                    An interactive showcase engineered for developer portfolios. Experience procedural 3D motion and layout control.
                </p>
                <span class="text-[10px] uppercase tracking-widest text-neutral-500 animate-pulse">↓ Scroll to update coordinates</span>
            </div>
        </section>

        <!-- Section 2: Details -->
        <section class="h-screen w-full flex items-center justify-end px-8 md:px-24">
            <div class="max-w-md text-right">
                <span class="text-xs uppercase tracking-[0.3em] text-amber-500 font-semibold inline-block mb-3">02 // Fluid Geometry</span>
                <h2 class="heading-font text-3xl md:text-5xl font-bold mb-4">Procedural Lerping</h2>
                <p class="text-neutral-400 text-sm font-light leading-relaxed mb-6">
                    The canvas listens to window scroll telemetry and applies linear interpolation for cinematic frame movement.
                </p>
            </div>
        </section>

        <!-- Section 3: Final Callout -->
        <section class="h-screen w-full flex flex-col justify-center items-center text-center px-8">
            <h2 class="heading-font text-4xl md:text-7xl font-black tracking-tighter mb-6">DEPLOY COMPLETE.</h2>
            <p class="text-neutral-500 max-w-md text-sm font-light mb-8">
                Ready for recording. Copy, tweak the variables inside the script, and commit directly to your profile repository.
            </p>
        </section>
    </main>

    <!-- Three.js CDN link -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>
        // 3D Scene Initialization
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 5;

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        // Aesthetic Geometric Object Group
        const group = new THREE.Group();

        // Outer Ring
        const ringGeo = new THREE.TorusGeometry(1.3, 0.04, 16, 100);
        const ringMat = new THREE.MeshPhysicalMaterial({
            color: 0x333333,
            roughness: 0.1,
            metalness: 0.9,
            clearcoat: 1.0
        });
        const ring = new THREE.Mesh(ringGeo, ringMat);
        group.add(ring);

        // Golden Wireframe Core
        const coreGeo = new THREE.IcosahedronGeometry(0.8, 1);
        const coreMat = new THREE.MeshStandardMaterial({
            color: 0xd4af37, 
            wireframe: true,
            transparent: true,
            opacity: 0.35
        });
        const core = new THREE.Mesh(coreGeo, coreMat);
        group.add(core);

        scene.add(group);

        // Lighting Matrix
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
        scene.add(ambientLight);

        const lightTop = new THREE.DirectionalLight(0xffffff, 1.5);
        lightTop.position.set(5, 5, 4);
        scene.add(lightTop);

        const lightBottom = new THREE.DirectionalLight(0xd4af37, 1.0);
        lightBottom.position.set(-5, -5, 2);
        scene.add(lightBottom);

        // Tracking scroll updates
        let scrollPercent = 0;
        document.body.onscroll = () => {
            scrollPercent = (
                (document.documentElement.scrollTop || document.body.scrollTop) / 
                ((document.documentElement.scrollHeight || document.body.scrollHeight) - document.documentElement.clientHeight)
            ) * 100;
        };

        // Render Loop with Linear Interpolation (Lerp)
        const clock = new THREE.Clock();

        function animate() {
            requestAnimationFrame(animate);
            const time = clock.getElapsedTime();

            // Subtle base animation
            group.position.y = Math.sin(time * 0.4) * 0.08;
            core.rotation.y = time * 0.1;
            
            // Set targets based on active scroll section
            let targetX = 0;
            let targetY = 0;
            let targetRotX = 0.2;
            let targetRotY = time * 0.05;

            if (scrollPercent < 40) {
                targetX = window.innerWidth > 768 ? 1.3 : 0;
                targetRotY = (scrollPercent * 0.03) + (time * 0.05);
            } else if (scrollPercent >= 40 && scrollPercent < 75) {
                targetX = window.innerWidth > 768 ? -1.3 : 0;
                targetRotX = 1.0;
                targetRotY = -0.5 + (scrollPercent * 0.01);
            } else {
                targetX = 0;
                targetRotX = 0.3;
                targetRotY = time * 0.5;
            }

            // Smooth tracking engine (0.05 speed factor)
            group.position.x += (targetX - group.position.x) * 0.05;
            group.position.y += (targetY - group.position.y) * 0.05;
            group.rotation.x += (targetRotX - group.rotation.x) * 0.05;
            group.rotation.y += (targetRotY - group.rotation.y) * 0.05;

            renderer.render(scene, camera);
        }

        animate();

        // Canvas Responsive Handler
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
